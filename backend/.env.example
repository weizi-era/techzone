# Server Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# Database: TCB PostgreSQL (auto-configured by genie-tcb-db-integrator skill)
# Do NOT set DATABASE_URL manually

# CORS Configuration
# Set to "*" to allow all origins (default), or specify a URL like "http://localhost:5173"
# WARNING: Using "*" disables credentials (cookies, authorization headers)
CORS_ORIGIN=*

# Logging Configuration
# Log levels: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
